rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) 
                    && isValidId(userId)
                    && incoming().uid == userId 
                    && incoming().email == request.auth.token.email 
                    && incoming().role in ['Organizer', 'Participant'] 
                    && incoming().createdAt == request.time;
      allow update: if isOwner(userId)
                    && incoming().uid == userId
                    && incoming().email == existing().email
                    && incoming().role == existing().role
                    && incoming().createdAt == existing().createdAt;
    }

    // 2. Hubs Collection
    match /hubs/{hubId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && isValidId(hubId) 
                    && incoming().ownerUid == request.auth.uid 
                    && incoming().createdAt == request.time 
                    && incoming().hubName is string 
                    && incoming().hubName.size() <= 100;
      allow update: if isSignedIn() 
                    && existing().ownerUid == request.auth.uid 
                    && incoming().ownerUid == existing().ownerUid 
                    && incoming().createdAt == existing().createdAt 
                    && incoming().hubName is string 
                    && incoming().hubName.size() <= 100;
      allow delete: if isSignedIn() 
                    && existing().ownerUid == request.auth.uid;
    }

    // 3. Quizzes Collection
    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && isValidId(quizId) 
                    && get(/databases/$(database)/documents/hubs/$(incoming().hubId)).data.ownerUid == request.auth.uid 
                    && incoming().createdAt == request.time;
      allow update: if isSignedIn() 
                    && get(/databases/$(database)/documents/hubs/$(existing().hubId)).data.ownerUid == request.auth.uid 
                    && incoming().hubId == existing().hubId 
                    && incoming().createdAt == existing().createdAt;
      allow delete: if isSignedIn() 
                    && get(/databases/$(database)/documents/hubs/$(existing().hubId)).data.ownerUid == request.auth.uid;
    }

    // 4. Questions Collection
    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
                    && isValidId(questionId) 
                    && get(/databases/$(database)/documents/hubs/$(get(/databases/$(database)/documents/quizzes/$(incoming().quizId)).data.hubId)).data.ownerUid == request.auth.uid;
      allow update: if isSignedIn() 
                    && get(/databases/$(database)/documents/hubs/$(get(/databases/$(database)/documents/quizzes/$(existing().quizId)).data.hubId)).data.ownerUid == request.auth.uid 
                    && incoming().quizId == existing().quizId;
      allow delete: if isSignedIn() 
                    && get(/databases/$(database)/documents/hubs/$(get(/databases/$(database)/documents/quizzes/$(existing().quizId)).data.hubId)).data.ownerUid == request.auth.uid;
    }

    // 5. Attempts Collection
    match /attempts/{attemptId} {
      allow read: if isSignedIn() 
                  && (isOwner(existing().userId) 
                      || get(/databases/$(database)/documents/hubs/$(existing().hubId)).data.ownerUid == request.auth.uid);
      
      allow create: if isSignedIn() 
                    && isValidId(attemptId) 
                    && incoming().userId == request.auth.uid 
                    && incoming().score == 0 
                    && incoming().cheatFlags.size() == 0 
                    && incoming().status == 'In Progress' 
                    && incoming().createdAt == request.time 
                    && incoming().updatedAt == request.time;

      allow update: if isSignedIn() 
                    && isOwner(existing().userId) 
                    && existing().status == 'In Progress' 
                    && incoming().userId == existing().userId 
                    && incoming().quizId == existing().quizId 
                    && incoming().hubId == existing().hubId 
                    && incoming().createdAt == existing().createdAt 
                    && incoming().updatedAt == request.time;
    }
  }
}
