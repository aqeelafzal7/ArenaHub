rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /hubs/{hubId} {
      allow read: if isSignedIn();
      // An organizer's hubId is their own uid
      allow write: if isSignedIn() && hubId == request.auth.uid;
    }

    match /quizzes/{quizId} {
      allow read: if isSignedIn();
      // Organizers can only create/edit quizzes for their own hub
      allow write: if isSignedIn() && (
        (request.method == 'create' && request.resource.data.hubId == request.auth.uid) ||
        (request.method != 'create' && resource.data.hubId == request.auth.uid)
      );
    }

    match /questions/{questionId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /attempts/{attemptId} {
      // Participants can view their own history. Organizers can check everything inside their tenant scope.
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.hubId == request.auth.uid
      );
      
      // Allow initial creation if it matches the current user context
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Incremental verification updates during proctoring events:
      allow update: if isSignedIn() && (
        // Organizers have overriding privileges
        resource.data.hubId == request.auth.uid ||
        // Participants can append to their active tracking array but cannot retroactively modify fixed credentials
        (
          resource.data.userId == request.auth.uid &&
          resource.data.status == "In Progress" &&
          request.resource.data.score == resource.data.score
        )
      );
      
      allow delete: if false; // Incident data records are permanent
    }
  }
}
